# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── NextAuth ──────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ─── CrossRef (polite pool — add your institutional email) ─────────────────
CROSSREF_EMAIL="research@slu.edu"

# ─── PubMed / NCBI ─────────────────────────────────────────────────────────
# Register at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=""

# ─── ORCID API ─────────────────────────────────────────────────────────────
# Register at: https://info.orcid.org/documentation/integration-guide/
ORCID_CLIENT_ID=""
ORCID_CLIENT_SECRET=""

# ─── SerpAPI (Google Scholar, optional) ────────────────────────────────────
# Register at: https://serpapi.com/ (~$50/mo for basic plan)
SERPAPI_KEY=""
